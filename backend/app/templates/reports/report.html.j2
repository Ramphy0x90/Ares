<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ scan.id }} - Ares Security Report</title>
<style>
  :root {
    --critical: #dc2626;
    --high: #ea580c;
    --medium: #ca8a04;
    --low: #2563eb;
    --info: #6b7280;
    --bg: #0f1117;
    --surface: #1a1d27;
    --surface2: #242734;
    --border: #2e3142;
    --text: #e2e4ea;
    --text-muted: #9194a1;
    --accent: #7c4dff;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; }
  .container { max-width: 1100px; margin: 0 auto; padding: 40px 24px; }

  /* Header */
  .header { text-align: center; margin-bottom: 48px; padding-bottom: 32px; border-bottom: 2px solid var(--accent); }
  .header h1 { font-size: 2.4em; font-weight: 700; letter-spacing: 6px; color: var(--accent); margin-bottom: 4px; }
  .header .subtitle { color: var(--text-muted); font-size: 1em; }

  /* Executive summary */
  .exec-summary { background: var(--surface); border-radius: 12px; padding: 28px 32px; margin-bottom: 32px; border: 1px solid var(--border); }
  .exec-summary h2 { color: var(--accent); margin-bottom: 16px; font-size: 1.3em; }
  .meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 20px; }
  .meta-item { background: var(--surface2); border-radius: 8px; padding: 14px 18px; }
  .meta-item .label { color: var(--text-muted); font-size: 0.8em; text-transform: uppercase; letter-spacing: 1px; }
  .meta-item .value { font-size: 1.15em; font-weight: 600; margin-top: 2px; }

  /* Risk badge */
  .risk-badge { display: inline-block; padding: 6px 18px; border-radius: 20px; font-weight: 700; font-size: 0.95em; text-transform: uppercase; letter-spacing: 1px; }
  .risk-Critical { background: rgba(220,38,38,0.15); color: var(--critical); border: 1px solid var(--critical); }
  .risk-High { background: rgba(234,88,12,0.15); color: var(--high); border: 1px solid var(--high); }
  .risk-Medium { background: rgba(202,138,4,0.15); color: var(--medium); border: 1px solid var(--medium); }
  .risk-Low { background: rgba(37,99,235,0.15); color: var(--low); border: 1px solid var(--low); }
  .risk-Informational { background: rgba(107,114,128,0.15); color: var(--info); border: 1px solid var(--info); }

  /* Severity chart */
  .severity-chart { background: var(--surface); border-radius: 12px; padding: 28px 32px; margin-bottom: 32px; border: 1px solid var(--border); }
  .severity-chart h2 { color: var(--accent); margin-bottom: 20px; font-size: 1.3em; }
  .bar-chart { display: flex; flex-direction: column; gap: 12px; }
  .bar-row { display: flex; align-items: center; gap: 12px; }
  .bar-label { width: 80px; text-align: right; font-size: 0.85em; font-weight: 600; text-transform: uppercase; }
  .bar-track { flex: 1; height: 28px; background: var(--surface2); border-radius: 6px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 6px; display: flex; align-items: center; justify-content: flex-end; padding-right: 10px; font-size: 0.8em; font-weight: 700; min-width: fit-content; transition: width 0.3s; }
  .bar-count { width: 36px; text-align: center; font-weight: 700; }

  /* Findings table */
  .findings-section { background: var(--surface); border-radius: 12px; padding: 28px 32px; margin-bottom: 32px; border: 1px solid var(--border); }
  .findings-section h2 { color: var(--accent); margin-bottom: 20px; font-size: 1.3em; }
  table { width: 100%; border-collapse: collapse; }
  th { text-align: left; padding: 10px 12px; color: var(--text-muted); font-size: 0.8em; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid var(--border); }
  td { padding: 12px; border-bottom: 1px solid var(--border); font-size: 0.92em; }
  tr:hover td { background: var(--surface2); }

  .sev-badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 0.75em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
  .sev-critical { background: rgba(220,38,38,0.15); color: var(--critical); }
  .sev-high { background: rgba(234,88,12,0.15); color: var(--high); }
  .sev-medium { background: rgba(202,138,4,0.15); color: var(--medium); }
  .sev-low { background: rgba(37,99,235,0.15); color: var(--low); }
  .sev-info { background: rgba(107,114,128,0.15); color: var(--info); }

  /* Detail cards */
  .finding-detail { background: var(--surface); border-radius: 12px; padding: 24px 28px; margin-bottom: 20px; border: 1px solid var(--border); border-left: 4px solid var(--info); }
  .finding-detail.sev-border-critical { border-left-color: var(--critical); }
  .finding-detail.sev-border-high { border-left-color: var(--high); }
  .finding-detail.sev-border-medium { border-left-color: var(--medium); }
  .finding-detail.sev-border-low { border-left-color: var(--low); }
  .finding-detail h3 { font-size: 1.1em; margin-bottom: 8px; display: flex; align-items: center; gap: 10px; }
  .finding-detail .desc { color: var(--text-muted); margin-bottom: 12px; }
  .finding-detail .field-label { font-size: 0.8em; color: var(--accent); text-transform: uppercase; letter-spacing: 1px; margin-top: 12px; margin-bottom: 4px; }
  .evidence-box { background: var(--bg); border-radius: 6px; padding: 12px 16px; font-family: 'Cascadia Code', 'Fira Code', monospace; font-size: 0.85em; white-space: pre-wrap; word-break: break-all; color: var(--text-muted); border: 1px solid var(--border); }

  /* Remediation checklist */
  .checklist { background: var(--surface); border-radius: 12px; padding: 28px 32px; margin-bottom: 32px; border: 1px solid var(--border); }
  .checklist h2 { color: var(--accent); margin-bottom: 20px; font-size: 1.3em; }
  .checklist-item { display: flex; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); }
  .checklist-item:last-child { border-bottom: none; }
  .check-box { width: 18px; height: 18px; border: 2px solid var(--border); border-radius: 4px; flex-shrink: 0; margin-top: 3px; }

  .footer { text-align: center; color: var(--text-muted); font-size: 0.8em; padding-top: 24px; border-top: 1px solid var(--border); }

  @media print {
    body { background: white; color: #111; }
    .container { max-width: 100%; }
    .header h1 { color: #333; }
    .exec-summary, .severity-chart, .findings-section, .finding-detail, .checklist { border-color: #ddd; background: #fafafa; }
    .meta-item { background: #f0f0f0; }
    .bar-track { background: #e5e5e5; }
    .evidence-box { background: #f5f5f5; border-color: #ddd; color: #333; }
  }
</style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <div class="header">
    <h1>ARES</h1>
    <div class="subtitle">Automated Reconnaissance &amp; Exploitation System &mdash; Security Report</div>
  </div>

  <!-- Executive Summary -->
  <div class="exec-summary">
    <h2>Executive Summary</h2>
    <div class="meta-grid">
      <div class="meta-item">
        <div class="label">Target</div>
        <div class="value">{{ target.name }}</div>
      </div>
      <div class="meta-item">
        <div class="label">Host</div>
        <div class="value">{{ target.host }}</div>
      </div>
      <div class="meta-item">
        <div class="label">Target Type</div>
        <div class="value">{{ target.target_type }}</div>
      </div>
      <div class="meta-item">
        <div class="label">Scan ID</div>
        <div class="value">#{{ scan.id }}</div>
      </div>
      <div class="meta-item">
        <div class="label">Status</div>
        <div class="value">{{ scan.status | upper }}</div>
      </div>
      <div class="meta-item">
        <div class="label">Duration</div>
        <div class="value">{{ duration or 'N/A' }}</div>
      </div>
      <div class="meta-item">
        <div class="label">Total Findings</div>
        <div class="value">{{ total_findings }}</div>
      </div>
      <div class="meta-item">
        <div class="label">Risk Rating</div>
        <div class="value"><span class="risk-badge risk-{{ risk_rating }}">{{ risk_rating }}</span></div>
      </div>
    </div>
    <p style="color: var(--text-muted); font-size: 0.9em;">
      Generated on {{ generated_at }} using {{ scanner_names | length }} scanner module{{ 's' if scanner_names | length != 1 else '' }}:
      {{ scanner_names | join(', ') }}.
    </p>
  </div>

  <!-- Severity Distribution -->
  <div class="severity-chart">
    <h2>Severity Distribution</h2>
    {% set max_count = severity_counts.values() | max if total_findings > 0 else 1 %}
    <div class="bar-chart">
      {% for sev in ['critical', 'high', 'medium', 'low', 'info'] %}
      <div class="bar-row">
        <div class="bar-label" style="color: {{ severity_color(sev) }}">{{ sev }}</div>
        <div class="bar-track">
          <div class="bar-fill" style="width: {{ (severity_counts[sev] / max_count * 100) if max_count > 0 else 0 }}%; background: {{ severity_color(sev) }};">
            {% if severity_counts[sev] > 0 %}&nbsp;{% endif %}
          </div>
        </div>
        <div class="bar-count">{{ severity_counts[sev] }}</div>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- Findings Summary Table -->
  {% if vulnerabilities %}
  <div class="findings-section">
    <h2>Findings Summary</h2>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Title</th>
          <th>Severity</th>
          <th>CVSS</th>
          <th>Scanner</th>
          <th>CWE</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {% for v in vulnerabilities %}
        <tr>
          <td>{{ loop.index }}</td>
          <td>{{ v.title }}</td>
          <td><span class="sev-badge sev-{{ v.severity | lower }}">{{ v.severity }}</span></td>
          <td>{{ '%.1f' | format(v.cvss_score) if v.cvss_score else '—' }}</td>
          <td>{{ v.scanner_name }}</td>
          <td>{{ v.cwe_id or '—' }}</td>
          <td>{{ v.status }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <!-- Detailed Findings -->
  <h2 style="color: var(--accent); margin-bottom: 20px; font-size: 1.3em;">Detailed Findings</h2>
  {% for v in vulnerabilities %}
  <div class="finding-detail sev-border-{{ v.severity | lower }}">
    <h3>
      <span class="sev-badge sev-{{ v.severity | lower }}">{{ v.severity }}</span>
      {{ v.title }}
    </h3>
    <div class="desc">{{ v.description }}</div>

    {% if v.affected_component %}
    <div class="field-label">Affected Component</div>
    <div>{{ v.affected_component }}</div>
    {% endif %}

    {% if v.cvss_score %}
    <div class="field-label">CVSS Score</div>
    <div>{{ '%.1f' | format(v.cvss_score) }}{% if v.cwe_id %} &middot; {{ v.cwe_id }}{% endif %}</div>
    {% endif %}

    {% if v.evidence %}
    <div class="field-label">Evidence</div>
    <div class="evidence-box">{{ v.evidence }}</div>
    {% endif %}

    {% if v.remediation %}
    <div class="field-label">Remediation</div>
    <div>{{ v.remediation }}</div>
    {% endif %}
  </div>
  {% endfor %}

  <!-- Remediation Checklist -->
  <div class="checklist">
    <h2>Remediation Checklist</h2>
    {% set seen = [] %}
    {% for v in vulnerabilities %}
      {% if v.remediation and v.remediation not in seen %}
        {% if seen.append(v.remediation) %}{% endif %}
        <div class="checklist-item">
          <div class="check-box"></div>
          <div>
            <strong>[{{ v.severity | upper }}]</strong> {{ v.remediation }}
            <span style="color: var(--text-muted); font-size: 0.85em;">&mdash; {{ v.title }}</span>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  {% else %}
  <div class="findings-section">
    <h2>Findings</h2>
    <p style="color: var(--text-muted);">No vulnerabilities were detected during this scan.</p>
  </div>
  {% endif %}

  <!-- Footer -->
  <div class="footer">
    <p>Generated by <strong>Ares</strong> &mdash; Automated Reconnaissance &amp; Exploitation System</p>
    <p>Report generated {{ generated_at }}</p>
  </div>

</div>
</body>
</html>
